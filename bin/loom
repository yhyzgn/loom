#!/usr/bin/env python3
import argparse, datetime as dt, fnmatch, hashlib, json, os, platform as py_platform, shutil, stat, subprocess, sys, time
from pathlib import Path

HUB = Path(__file__).resolve().parents[1]
MANIFEST = HUB / 'config' / 'manifest.json'
LOCK = HUB / '.loom.lock'
LOG_DIR = HUB / 'logs'
STATE_DIR = HUB / 'state'
HOOK_MARKER = 'loom/bin/loom hook'


def log(msg):
    print(msg)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    with (LOG_DIR / 'loom.log').open('a') as f:
        f.write(f"{dt.datetime.now().isoformat()} {msg}\n")


def run(cmd, cwd=HUB, check=False, capture=True):
    p = subprocess.run(cmd, cwd=str(cwd), text=True, stdout=subprocess.PIPE if capture else None, stderr=subprocess.STDOUT if capture else None)
    if check and p.returncode != 0:
        raise RuntimeError(f"command failed {cmd}: {p.stdout}")
    return p


def load_manifest():
    return json.loads(MANIFEST.read_text())


def sha256_path(p):
    h = hashlib.sha256()
    with open(p, 'rb') as f:
        for b in iter(lambda: f.read(1024 * 1024), b''):
            h.update(b)
    return h.hexdigest()


def is_excluded(path, patterns):
    s = str(path)
    return any(fnmatch.fnmatch(s, pat) or fnmatch.fnmatch('/' + s, pat) for pat in patterns)


def ensure_parent(p):
    p.parent.mkdir(parents=True, exist_ok=True)


def backup_target(target, backup_root):
    t = Path(target)
    if not t.exists() and not t.is_symlink():
        return None
    rel = str(t).lstrip('/').replace('/', '__')
    stamp = dt.datetime.now().strftime('%Y%m%d%H%M%S')
    b = Path(backup_root) / f'{rel}.{stamp}.bak'
    b.parent.mkdir(parents=True, exist_ok=True)
    if t.is_dir() and not t.is_symlink():
        shutil.copytree(t, b, symlinks=True)
    else:
        shutil.copy2(t, b)
    return b


def copy_file(src, dst, mode=None):
    ensure_parent(dst)
    shutil.copy2(src, dst)
    if mode:
        os.chmod(dst, int(mode, 8))


def copy_dir(src, dst, exclude_patterns):
    src = Path(src); dst = Path(dst)
    if dst.exists():
        shutil.rmtree(dst)
    def ignore(dirpath, names):
        ignored=[]
        base=Path(dirpath)
        for n in names:
            p=base/n
            rel=p.relative_to(src)
            if is_excluded(rel, exclude_patterns) or is_excluded(p, exclude_patterns):
                ignored.append(n)
        return ignored
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(src, dst, ignore=ignore, symlinks=True)


def validate_json(path):
    with open(path) as f:
        return json.load(f)


def validate_codex_hooks(path):
    j = validate_json(path)
    if set(j.keys()) != {'hooks'}:
        raise ValueError(f'{path} must have only top-level hooks key, got {list(j.keys())}')
    return j


SENSITIVE_SENTINEL = "__AGENT_SYNC_LOCAL_SECRET__"
SENSITIVE_KEY_PARTS = ('token', 'apikey', 'api_key', 'secret', 'password', 'credential', 'auth')


def is_sensitive_key(key):
    k = str(key).lower().replace('-', '_')
    # Do not treat general config words like selected auth method as secrets unless they hold credentials.
    if k in ('auth', 'authentication', 'selectedtype', 'selected_type'):
        return False
    return any(part in k for part in SENSITIVE_KEY_PARTS)


def contains_sensitive_key(value):
    if isinstance(value, dict):
        for k, v in value.items():
            if is_sensitive_key(k):
                return True
            if contains_sensitive_key(v):
                return True
    elif isinstance(value, list):
        return any(contains_sensitive_key(v) for v in value)
    return False


def sanitize_json_value(value, key=''):
    if is_sensitive_key(key) and isinstance(value, (str, int, float, bool)) and value not in ('', None):
        return SENSITIVE_SENTINEL
    if isinstance(value, dict):
        return {k: sanitize_json_value(v, k) for k, v in value.items()}
    if isinstance(value, list):
        return [sanitize_json_value(v, key) for v in value]
    return value


def merge_preserve_local_secrets(src, local):
    if src == SENSITIVE_SENTINEL:
        return local if local is not None else src
    if isinstance(src, dict):
        local = local if isinstance(local, dict) else {}
        return {k: merge_preserve_local_secrets(v, local.get(k)) for k, v in src.items()}
    if isinstance(src, list):
        local = local if isinstance(local, list) else []
        out=[]
        for i, v in enumerate(src):
            out.append(merge_preserve_local_secrets(v, local[i] if i < len(local) else None))
        return out
    return src


def export_local(manifest):
    changed=[]
    patterns=manifest.get('exclude_globs', [])
    for item in manifest['managed_files']:
        src = HUB / item['source']
        tgt = Path(item['target'])
        if not tgt.exists():
            continue
        if is_excluded(tgt, patterns):
            continue
        src.parent.mkdir(parents=True, exist_ok=True)
        if item['type'] == 'dir':
            copy_dir(tgt, src, patterns)
        elif item['type'] == 'json':
            data = validate_json(tgt)
            if contains_sensitive_key(data):
                log(f'skip sensitive json export {item["name"]}: {tgt}')
                continue
            src.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n')
        else:
            copy_file(tgt, src, item.get('mode'))
        changed.append(item['name'])
    return changed


def apply_repo(manifest):
    applied=[]
    patterns=manifest.get('exclude_globs', [])
    backup_root=manifest.get('backup_root', '/home/neo/.loom-backups')
    for item in manifest['managed_files']:
        src = HUB / item['source']
        tgt = Path(item['target'])
        if not src.exists():
            continue
        if item.get('schema') == 'codex-hooks' or (item['type'] == 'json' and tgt.name == 'hooks.json' and '.codex' in str(tgt)):
            validate_codex_hooks(src)
        elif item['type'] == 'json':
            validate_json(src)
        backup_target(tgt, backup_root)
        if item['type'] == 'dir':
            copy_dir(src, tgt, patterns)
        elif item['type'] == 'json':
            source_data = validate_json(src)
            local_data = validate_json(tgt) if tgt.exists() and tgt.read_text().strip() else None
            merged = merge_preserve_local_secrets(source_data, local_data)
            ensure_parent(tgt)
            tgt.write_text(json.dumps(merged, indent=2, ensure_ascii=False) + '\n')
        else:
            copy_file(src, tgt, item.get('mode'))
        applied.append(item['name'])
    return applied


def git_has_repo():
    return (HUB / '.git').exists()


def git_init_if_needed():
    if not git_has_repo():
        run(['git', 'init'], check=True)
        run(['git', 'branch', '-M', 'main'], check=False)
    gitignore = HUB / '.gitignore'
    if not gitignore.exists():
        gitignore.write_text('\n'.join(['logs/*.log', '.agent-sync.lock', 'state/*.tmp', '', '# never store secrets/caches', '**/auth.json', '**/*credentials*.json', '**/oauth*.json', '**/node_modules/', '**/tmp/', '**/cache/', '**/sessions/', '**/*.db*']) + '\n')


def git_commit(message):
    git_init_if_needed()
    run(['git', 'add', '-A'], check=True)
    status = run(['git', 'status', '--porcelain']).stdout.strip()
    if not status:
        return False
    run(['git', 'commit', '-m', message], check=True)
    return True


def has_origin():
    if not git_has_repo():
        return False
    return run(['git', 'remote', 'get-url', 'origin']).returncode == 0


def pull_rebase():
    if not has_origin():
        log('No git origin configured; skip pull')
        return False
    p=run(['git', 'pull', '--rebase', '--autostash', 'origin', 'main'])
    log(p.stdout.strip() or 'pull ok')
    return p.returncode == 0


def push():
    if not has_origin():
        log('No git origin configured; skip push')
        return False
    p=run(['git', 'push', 'origin', 'HEAD:main'])
    log(p.stdout.strip() or 'push ok')
    return p.returncode == 0


def escape_toml_basic(s):
    return s.replace('\\', '\\\\').replace('"', '\\"')


def codex_event_label(event):
    out=[]
    for i,ch in enumerate(event):
        if ch.isupper() and i:
            out.append('_')
        out.append(ch.lower())
    return ''.join(out)


def canonical_json(value):
    if isinstance(value, list):
        return [canonical_json(v) for v in value]
    if isinstance(value, dict):
        return {k: canonical_json(value[k]) for k in sorted(value)}
    return value


def codex_trusted_hash(event, entry, hook):
    identity = {
        'event_name': codex_event_label(event),
        'hooks': [{
            'type': hook.get('type', 'command'),
            'command': hook['command'],
            'timeout': max(1, hook.get('timeout', 600)),
            'async': False,
        }]
    }
    if entry.get('matcher'):
        identity['matcher'] = entry['matcher']
    payload = json.dumps(canonical_json(identity), separators=(',', ':'))
    return 'sha256:' + hashlib.sha256(payload.encode()).hexdigest()


def update_codex_config_trust(hooks_path):
    hooks_path = Path(hooks_path)
    config_path = hooks_path.parent / 'config.toml'
    if not config_path.exists() or not hooks_path.exists():
        return
    data = validate_codex_hooks(hooks_path)
    text = config_path.read_text()
    additions = []
    import re
    for event, entries in data.get('hooks', {}).items():
        label = codex_event_label(event)
        for gi, entry in enumerate(entries):
            for hi, hook in enumerate(entry.get('hooks', [])):
                if not isinstance(hook, dict) or hook.get('type') != 'command' or 'command' not in hook:
                    continue
                key = f'{hooks_path}:{label}:{gi}:{hi}'
                trusted = codex_trusted_hash(event, entry, hook)
                pattern = re.compile(r'(\[hooks\.state\."' + re.escape(key) + r'"\]\ntrusted_hash = ")[^"]*(")')
                if pattern.search(text):
                    text = pattern.sub(r'\1' + trusted + r'\2', text)
                else:
                    additions.append(f'\n[hooks.state."{escape_toml_basic(key)}"]\ntrusted_hash = "{trusted}"\n')
    if additions:
        if not text.endswith('\n'):
            text += '\n'
        text += ''.join(additions)
    config_path.write_text(text)


def hook_phase_for_event(event):
    e = str(event).lower()
    if e in ('stop', 'sessionend', 'session_end', 'exit'):
        return 'exit'
    return 'start'


def install_hooks(manifest):
    installed=[]
    hook_cmd = f'"{HUB}/bin/loom" hook --platform "{{platform}}"'
    for h in manifest.get('hook_install', []):
        platform=h['platform']; settings=Path(h['settings']); event=h['event']
        settings.parent.mkdir(parents=True, exist_ok=True)
        data={}
        if settings.exists() and settings.read_text().strip():
            data=json.loads(settings.read_text())
        hooks=data.setdefault('hooks', {})
        arr=hooks.setdefault(event, [])
        phase = hook_phase_for_event(event)
        cmd = hook_cmd.format(platform=platform) + f' --phase {phase}'
        def is_agent_sync_hook(hook):
            return isinstance(hook, dict) and any(marker in hook.get('command', '') for marker in (f'{HUB}/bin/loom', f'{HUB}/bin/agent-sync', '/home/neo/Projects/neo/pub/agent-config-hub/bin/loom', '/home/neo/Projects/neo/pub/agent-config-hub/bin/agent-sync'))
        cleaned=[]
        changed=False
        for group in arr:
            group_hooks = group.get('hooks', []) if isinstance(group, dict) else []
            remaining = [hh for hh in group_hooks if not is_agent_sync_hook(hh)]
            if len(remaining) != len(group_hooks):
                changed=True
            if remaining:
                ng = dict(group)
                ng['hooks'] = remaining
                cleaned.append(ng)
        cleaned.append({'hooks':[{'type':'command','command':cmd,'timeout':30}]})
        hooks[event] = cleaned
        if changed or arr != cleaned:
            settings.write_text(json.dumps(data, indent=2, ensure_ascii=False)+'\n')
            installed.append(platform)
        if h.get('schema') == 'codex-hooks-json':
            validate_codex_hooks(settings)
            update_codex_config_trust(settings)
    return installed


def doctor(manifest):
    errors=[]
    for item in manifest['managed_files']:
        src=HUB/item['source']; tgt=Path(item['target'])
        if not src.exists(): errors.append(f'missing source {item["name"]}: {src}')
        if item['type']=='json' and src.exists():
            try:
                if item.get('schema') == 'codex-hooks': validate_codex_hooks(src)
                else: validate_json(src)
            except Exception as e: errors.append(str(e))
    for h in manifest.get('hook_install', []):
        p=Path(h['settings'])
        if p.exists():
            try:
                j=json.loads(p.read_text())
                if h.get('schema') == 'codex-hooks-json' and set(j.keys()) != {'hooks'}:
                    errors.append(f'{p} has invalid top-level keys {list(j.keys())}')
            except Exception as e: errors.append(f'{p}: {e}')
    if errors:
        for e in errors: log('ERROR '+e)
        return 1
    log('doctor ok')
    return 0


def acquire_lock():
    start=time.time()
    while True:
        try:
            fd=os.open(LOCK, os.O_CREAT|os.O_EXCL|os.O_WRONLY)
            os.write(fd, str(os.getpid()).encode()); os.close(fd); return
        except FileExistsError:
            if time.time()-start > 20:
                raise RuntimeError('agent-sync lock timeout')
            time.sleep(0.5)


def release_lock():
    try: LOCK.unlink()
    except FileNotFoundError: pass


def install_shims():
    commands = ['codex', 'gemini', 'opencode', 'claude', 'hermes']
    shimdir = HUB / 'shims'
    shimdir.mkdir(parents=True, exist_ok=True)
    current_path = os.environ.get('PATH', '')
    search_path = ':'.join([x for x in current_path.split(':') if x and Path(x).resolve() != shimdir.resolve()])
    installed = []
    for c in commands:
        real = shutil.which(c, path=search_path)
        if not real:
            continue
        script = (
            '#!/usr/bin/env bash\n'
            'set -uo pipefail\n'
            f'AGENT_SYNC_HUB="{HUB}"\n'
            f'AGENT_SYNC_PLATFORM="{c}"\n'
            f'AGENT_SYNC_REAL="{real}"\n'
            f'AGENT_SYNC_LOG="/tmp/agent-sync-{c}.log"\n'
            'agent_sync_run() {\n'
            '  local phase="$1"\n'
            '  if [ "${AGENT_SYNC_SHIM_BYPASS:-0}" != "1" ]; then\n'
            '    AGENT_SYNC_SHIM_BYPASS=1 "$AGENT_SYNC_HUB/bin/loom" hook --platform "$AGENT_SYNC_PLATFORM" --phase "$phase" >>"$AGENT_SYNC_LOG" 2>&1 || true\n'
            '  fi\n'
            '}\n'
            'agent_sync_on_exit() {\n'
            '  local status=$?\n'
            '  agent_sync_run exit\n'
            '  exit "$status"\n'
            '}\n'
            'agent_sync_run start\n'
            'trap agent_sync_on_exit EXIT\n'
            '"$AGENT_SYNC_REAL" "$@"\n'
            'status=$?\n'
            'exit "$status"\n'
        )
        out = shimdir / c
        out.write_text(script)
        out.chmod(0o755)
        installed.append(c)
    block = '# >>> loom shims >>>\nexport PATH="$HOME/Projects/neo/pub/loom/bin:$HOME/Projects/neo/pub/loom/shims:$PATH"\n# <<< loom shims <<<\n'
    for rc_name in ['.bashrc', '.zshrc']:
        rc = Path.home() / rc_name
        old = rc.read_text() if rc.exists() else ''
        if '# >>> loom shims >>>' in old and '# <<< loom shims <<<' in old:
            pre = old.split('# >>> loom shims >>>')[0].rstrip()
            post = old.split('# <<< loom shims <<<', 1)[1]
            rc.write_text(pre + '\n' + block + post)
        else:
            rc.write_text(old.rstrip() + '\n\n' + block)
    log('installed command shims with start/exit sync: ' + ', '.join(installed))
    return installed


def systemd_user_dir():
    return Path.home() / '.config' / 'systemd' / 'user'


def macos_launch_agents_dir():
    return Path.home() / 'Library' / 'LaunchAgents'


def windows_startup_dir():
    base = os.environ.get('APPDATA')
    if base:
        return Path(base) / 'Microsoft' / 'Windows' / 'Start Menu' / 'Programs' / 'Startup'
    return Path.home() / 'AppData' / 'Roaming' / 'Microsoft' / 'Windows' / 'Start Menu' / 'Programs' / 'Startup'


def install_timer(interval_minutes=5, target_os=None):
    interval_minutes = max(1, int(interval_minutes))
    system = (target_os or py_platform.system()).lower()
    if system in ('linux', 'linux2'):
        return install_linux_timer(interval_minutes)
    if system in ('darwin', 'mac', 'macos'):
        return install_macos_timer(interval_minutes)
    if system in ('windows', 'win32', 'cygwin', 'msys'):
        return install_windows_timer(interval_minutes)
    log(f'unsupported timer platform: {system}')
    return False


def install_linux_timer(interval_minutes):
    user_dir = systemd_user_dir()
    user_dir.mkdir(parents=True, exist_ok=True)
    service = user_dir / 'loom-sync.service'
    timer = user_dir / 'loom-sync.timer'
    service.write_text(
        '[Unit]\n'
        'Description=Sync agent harness configuration hub\n\n'
        '[Service]\n'
        'Type=oneshot\n'
        f'WorkingDirectory={HUB}\n'
        f'ExecStart={HUB}/bin/loom hook --platform timer --phase timer\n'
    )
    timer.write_text(
        '[Unit]\n'
        'Description=Periodic sync for agent harness configuration hub\n\n'
        '[Timer]\n'
        'OnBootSec=2min\n'
        f'OnUnitActiveSec={interval_minutes}min\n'
        'Persistent=true\n\n'
        '[Install]\n'
        'WantedBy=timers.target\n'
    )
    if shutil.which('systemctl'):
        run(['systemctl', '--user', 'daemon-reload'], cwd=HUB, capture=True)
        enable = run(['systemctl', '--user', 'enable', '--now', 'loom-sync.timer'], cwd=HUB, capture=True)
        if enable.returncode != 0:
            log('Linux timer files installed, but systemctl enable failed: ' + (enable.stdout or '').strip())
            return False
        log(f'installed and enabled Linux systemd user timer every {interval_minutes} minutes')
        return True
    log('Linux timer files installed, but systemctl command not found')
    return False


def install_macos_timer(interval_minutes):
    launch_dir = macos_launch_agents_dir()
    launch_dir.mkdir(parents=True, exist_ok=True)
    plist = launch_dir / 'com.neo.loom.sync.plist'
    interval_seconds = interval_minutes * 60
    plist_text = '\n'.join([
        f'<?xml version="1.0" encoding="UTF-8"?>',
        f'<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">',
        f'<plist version="1.0">',
        f'<dict>',
        f'  <key>Label</key>',
        f'  <string>com.loom.sync</string>',
        f'  <key>ProgramArguments</key>',
        f'  <array>',
        f'    <string>{HUB}/bin/loom</string>',
        f'    <string>hook</string>',
        f'    <string>--platform</string>',
        f'    <string>timer</string>',
        f'    <string>--phase</string>',
        f'    <string>timer</string>',
        f'  </array>',
        f'  <key>WorkingDirectory</key>',
        f'  <string>{HUB}</string>',
        f'  <key>StartInterval</key>',
        f'  <integer>{interval_seconds}</integer>',
        f'  <key>RunAtLoad</key>',
        f'  <true/>',
        f'  <key>StandardOutPath</key>',
        f'  <string>{HUB}/logs/launchd.out.log</string>',
        f'  <key>StandardErrorPath</key>',
        f'  <string>{HUB}/logs/launchd.err.log</string>',
        f'</dict>',
        f'</plist>',
        ''
    ])
    plist.write_text(plist_text)
    if shutil.which('launchctl'):
        run(['launchctl', 'unload', str(plist)], cwd=HUB, capture=True)
        load = run(['launchctl', 'load', '-w', str(plist)], cwd=HUB, capture=True)
        if load.returncode != 0:
            log('macOS launchd plist installed, but launchctl load failed: ' + (load.stdout or '').strip())
            return False
        log(f'installed and loaded macOS launchd timer every {interval_minutes} minutes')
        return True
    log(f'macOS launchd plist installed at {plist}; run launchctl load -w {plist}')
    return False


def install_windows_timer(interval_minutes):
    scripts_dir = HUB / 'scripts'
    scripts_dir.mkdir(parents=True, exist_ok=True)
    ps1 = scripts_dir / 'loom-timer.ps1'
    ps1.write_text(
        '$ErrorActionPreference = "SilentlyContinue"\n'
        f'Set-Location -LiteralPath "{HUB}"\n'
        f'& "{HUB}/bin/loom" hook --platform timer --phase timer *>> "{HUB}/logs/windows-task.log"\n'
    )
    task_name = 'LoomSync'
    if shutil.which('schtasks'):
        create = run(['schtasks', '/Create', '/TN', task_name, '/SC', 'MINUTE', '/MO', str(interval_minutes), '/TR', f'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "{ps1}"', '/F'], cwd=HUB, capture=True)
        if create.returncode != 0:
            log('Windows scheduled task script installed, but schtasks create failed: ' + (create.stdout or '').strip())
            return False
        log(f'installed Windows Scheduled Task {task_name} every {interval_minutes} minutes')
        return True
    startup = windows_startup_dir()
    startup.mkdir(parents=True, exist_ok=True)
    starter = startup / 'loom-sync.cmd'
    starter.write_text('@echo off\r\n' + f'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "{ps1}"\r\n')
    log(f'Windows timer script installed at {ps1}; schtasks not found, startup fallback written to {starter}')
    return False


def timer_status(target_os=None):
    system = (target_os or py_platform.system()).lower()
    if system in ('linux', 'linux2') and shutil.which('systemctl'):
        p = run(['systemctl', '--user', 'list-timers', 'loom-sync.timer', '--no-pager'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no systemd timer status output')
        return p.returncode
    if system in ('darwin', 'mac', 'macos') and shutil.which('launchctl'):
        p = run(['launchctl', 'list', 'com.neo.loom.sync'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no launchd status output')
        return p.returncode
    if system in ('windows', 'win32', 'cygwin', 'msys') and shutil.which('schtasks'):
        p = run(['schtasks', '/Query', '/TN', 'LoomSync'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no schtasks status output')
        return p.returncode
    log(f'no native timer status command available for {system}')
    return 1

def cmd_sync(args):
    manifest=load_manifest(); git_init_if_needed()
    phase = getattr(args, "phase", "manual")
    platform = getattr(args, "platform", "manual")
    log(f'sync begin platform={platform} phase={phase}')
    changed=export_local(manifest); log(f'exported {len(changed)} managed entries')
    git_commit(f'agent-sync: capture local config {dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')
    pull_rebase()
    applied=apply_repo(manifest); log(f'applied {len(applied)} managed entries')
    install_hooks(manifest)
    git_commit(f'agent-sync: apply hook wiring {dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')
    push()
    return doctor(manifest)


def main():
    ap=argparse.ArgumentParser()
    sub=ap.add_subparsers(dest='cmd', required=True)
    sub.add_parser('export')
    sub.add_parser('apply')
    sub.add_parser('sync')
    sub.add_parser('doctor')
    sub.add_parser('install-hooks')
    sub.add_parser('install-shims')
    tp=sub.add_parser('install-timer'); tp.add_argument('--interval-minutes', type=int, default=5); tp.add_argument('--platform', choices=['linux','macos','windows'], default=None)
    tsp=sub.add_parser('timer-status'); tsp.add_argument('--platform', choices=['linux','macos','windows'], default=None)
    hp=sub.add_parser('hook'); hp.add_argument('--platform', default='unknown'); hp.add_argument('--phase', default='start', choices=['start', 'exit', 'timer', 'manual'])
    args=ap.parse_args()
    try:
        acquire_lock()
        manifest=load_manifest(); git_init_if_needed()
        if args.cmd == 'export':
            changed=export_local(manifest); log(f'exported {len(changed)} managed entries'); git_commit(f'agent-sync: export local config {dt.datetime.now().isoformat()}'); return 0
        if args.cmd == 'apply':
            pull_rebase(); applied=apply_repo(manifest); log(f'applied {len(applied)} managed entries'); install_hooks(manifest); return doctor(manifest)
        if args.cmd == 'sync': return cmd_sync(args)
        if args.cmd == 'doctor': return doctor(manifest)
        if args.cmd == 'install-hooks':
            installed=install_hooks(manifest); log('installed hooks: '+', '.join(installed)); return doctor(manifest)
        if args.cmd == 'install-shims':
            install_shims(); return 0
        if args.cmd == 'install-timer':
            install_timer(args.interval_minutes, args.platform); return doctor(manifest)
        if args.cmd == 'timer-status':
            return timer_status(args.platform)
        if args.cmd == 'hook':
            # Harness startup path: never block startup on remote/network failure.
            try: return cmd_sync(args)
            except Exception as e:
                log(f'hook sync skipped/failed for {args.platform}: {e}')
                return 0
    finally:
        release_lock()

if __name__ == '__main__':
    sys.exit(main())
