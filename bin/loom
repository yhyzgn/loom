#!/usr/bin/env python3
import argparse, datetime as dt, fnmatch, hashlib, json, os, platform as py_platform, shlex, shutil, stat, subprocess, sys, time
from pathlib import Path

def runtime_path():
    if getattr(sys, 'frozen', False):
        return Path(sys.executable).resolve()
    return Path(__file__).resolve()


def read_hub_sidecar(path):
    sidecar = path.with_name('loom-hub.json')
    if not sidecar.exists():
        return None
    try:
        data = json.loads(sidecar.read_text())
    except Exception:
        return None
    hub = Path(data.get('hub', '')).expanduser()
    return hub if (hub / 'config' / 'manifest.json').exists() else None


def find_hub_from(start):
    start = Path(start).resolve()
    roots = [start] if start.is_dir() else list(start.parents)
    for candidate in roots:
        if (candidate / 'config' / 'manifest.json').exists():
            return candidate
    return None


def valid_hub(path):
    return bool(path) and (Path(path) / 'config' / 'manifest.json').exists()


def discover_hub():
    env_hub = os.environ.get('LOOM_HUB')
    if env_hub:
        hub = Path(env_hub).expanduser().resolve()
        if valid_hub(hub):
            return hub
    exe = runtime_path()
    sidecar_hub = read_hub_sidecar(exe)
    if sidecar_hub:
        return sidecar_hub.resolve()
    return find_hub_from(exe) or find_hub_from(Path.cwd())


def hub_error_message():
    exe = runtime_path()
    return (
        'Cannot find loom hub checkout: config/manifest.json was not found near the executable, '
        'near the current directory, in LOOM_HUB, or in loom-hub.json.\n'
        f'Executable: {exe}\n'
        f'Current directory: {Path.cwd()}\n'
        'Run from a cloned loom checkout, or pass --hub <path-to-loom-checkout>, or set LOOM_HUB. '
        'On Windows, download/clone the loom repository first, then run: '
        './loom-windows-x86_64.exe --hub C:/path/to/loom install'
    )


def require_hub():
    if not HUB or not MANIFEST.exists():
        raise RuntimeError(hub_error_message())


def windows_platform(target_os=None):
    system = (target_os or py_platform.system()).lower()
    return system in ('windows', 'win32', 'cygwin', 'msys')


def quote_command_path(path):
    return f'"{path}"'


def cli_executable_path(target_os=None):
    if getattr(sys, 'frozen', False):
        return runtime_path()
    if windows_platform(target_os):
        exe = HUB / 'bin' / 'loom.exe'
        if exe.exists():
            return exe
        bat = HUB / 'bin' / 'loom.bat'
        if bat.exists():
            return bat
    return HUB / 'bin' / 'loom'


def command_for_cli(path=None, target_os=None):
    path = Path(path) if path else cli_executable_path(target_os)
    if windows_platform(target_os):
        return quote_command_path(path)
    return quote_command_path(path)


HUB = discover_hub()
MANIFEST = (HUB / 'config' / 'manifest.json') if HUB else Path('__loom_hub_not_found__') / 'config' / 'manifest.json'
LOCK = (HUB / '.loom.lock') if HUB else Path.cwd() / '.loom.lock'
LOG_DIR = (HUB / 'logs') if HUB else Path.cwd() / 'logs'
STATE_DIR = (HUB / 'state') if HUB else Path.cwd() / 'state'
HOOK_MARKER = 'loom/bin/loom hook'
LOOM_HOOK_COMMAND_PATTERNS = (
    'loom/bin/loom',
    'loom/bin/loom.exe',
    'loom\\bin\\loom',
    'loom\\bin\\loom.exe',
    '/bin/loom',
    '/bin/loom.exe',
    '\\bin\\loom',
    '\\bin\\loom.exe',
)


def log(msg):
    print(msg)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    with (LOG_DIR / 'loom.log').open('a') as f:
        f.write(f"{dt.datetime.now().isoformat()} {msg}\n")


def run(cmd, cwd=HUB, check=False, capture=True):
    p = subprocess.run(cmd, cwd=str(cwd), text=True, stdout=subprocess.PIPE if capture else None, stderr=subprocess.STDOUT if capture else None)
    if check and p.returncode != 0:
        raise RuntimeError(f"command failed {cmd}: {p.stdout}")
    return p


def load_manifest():
    require_hub()
    return json.loads(MANIFEST.read_text())


def today_key():
    return dt.datetime.now().astimezone().date().isoformat()


def auto_sync_state_path():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    return STATE_DIR / 'last-auto-sync.json'


def should_skip_auto_sync(args):
    force = bool(getattr(args, 'force', False))
    phase = getattr(args, 'phase', 'manual')
    platform = getattr(args, 'platform', 'manual')
    if force or phase == 'manual':
        return False
    p = auto_sync_state_path()
    if not p.exists():
        return False
    try:
        data = json.loads(p.read_text())
    except Exception:
        return False
    if data.get('date') == today_key():
        log(f'auto sync skipped platform={platform} phase={phase}: already synced today at {data.get("timestamp", "unknown")}')
        return True
    return False


def mark_auto_sync(args, status='ok'):
    phase = getattr(args, 'phase', 'manual')
    if phase == 'manual':
        return
    p = auto_sync_state_path()
    payload = {
        'date': today_key(),
        'timestamp': dt.datetime.now().astimezone().isoformat(),
        'platform': getattr(args, 'platform', 'unknown'),
        'phase': phase,
        'status': status,
    }
    p.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + '\n')


def sha256_path(p):
    h = hashlib.sha256()
    with open(p, 'rb') as f:
        for b in iter(lambda: f.read(1024 * 1024), b''):
            h.update(b)
    return h.hexdigest()


def is_excluded(path, patterns):
    s = str(path)
    return any(fnmatch.fnmatch(s, pat) or fnmatch.fnmatch('/' + s, pat) for pat in patterns)


def ensure_parent(p):
    p.parent.mkdir(parents=True, exist_ok=True)


def backup_target(target, backup_root):
    t = Path(target)
    if not t.exists() and not t.is_symlink():
        return None
    rel = str(t).lstrip('/').replace('/', '__')
    stamp = dt.datetime.now().strftime('%Y%m%d%H%M%S')
    b = Path(backup_root) / f'{rel}.{stamp}.bak'
    b.parent.mkdir(parents=True, exist_ok=True)
    if t.is_dir() and not t.is_symlink():
        shutil.copytree(t, b, symlinks=True)
    else:
        shutil.copy2(t, b)
    return b


def copy_file(src, dst, mode=None):
    ensure_parent(dst)
    shutil.copy2(src, dst)
    if mode:
        os.chmod(dst, int(mode, 8))


def copy_dir(src, dst, exclude_patterns):
    src = Path(src); dst = Path(dst)
    if dst.exists():
        shutil.rmtree(dst)
    def ignore(dirpath, names):
        ignored=[]
        base=Path(dirpath)
        for n in names:
            p=base/n
            rel=p.relative_to(src)
            if is_excluded(rel, exclude_patterns) or is_excluded(p, exclude_patterns):
                ignored.append(n)
        return ignored
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(src, dst, ignore=ignore, symlinks=True)


def validate_json(path):
    with open(path) as f:
        return json.load(f)


def validate_codex_hooks(path):
    j = validate_json(path)
    if set(j.keys()) != {'hooks'}:
        raise ValueError(f'{path} must have only top-level hooks key, got {list(j.keys())}')
    return j


SENSITIVE_SENTINEL = "__LOOM_LOCAL_SECRET__"
SENSITIVE_KEY_PARTS = ('token', 'apikey', 'api_key', 'secret', 'password', 'credential', 'auth')

REQUIRED_GLOBAL_MEMORY_MARKERS = (
    'SPRING-BOOT-4-MIGRATION',
    'DATABASE-SQL-REDLINES',
    'JAVA-SPRING-ORM-SQL-REDLINES',
    'MODULE-ENTRY-FILE-CONVENTION',
    'NO-WARNING-SUPPRESSION',
    'LOOM-AUTOSYNC',
)


def is_sensitive_key(key):
    k = str(key).lower().replace('-', '_')
    # Do not treat general config words like selected auth method as secrets unless they hold credentials.
    if k in ('auth', 'authentication', 'selectedtype', 'selected_type'):
        return False
    return any(part in k for part in SENSITIVE_KEY_PARTS)


def contains_sensitive_key(value):
    if isinstance(value, dict):
        for k, v in value.items():
            if is_sensitive_key(k):
                return True
            if contains_sensitive_key(v):
                return True
    elif isinstance(value, list):
        return any(contains_sensitive_key(v) for v in value)
    return False


def sanitize_json_value(value, key=''):
    if is_sensitive_key(key) and isinstance(value, (str, int, float, bool)) and value not in ('', None):
        return SENSITIVE_SENTINEL
    if isinstance(value, dict):
        return {k: sanitize_json_value(v, k) for k, v in value.items()}
    if isinstance(value, list):
        return [sanitize_json_value(v, key) for v in value]
    return value


def merge_preserve_local_secrets(src, local):
    if src == SENSITIVE_SENTINEL:
        return local if local is not None else src
    if isinstance(src, dict):
        local = local if isinstance(local, dict) else {}
        return {k: merge_preserve_local_secrets(v, local.get(k)) for k, v in src.items()}
    if isinstance(src, list):
        local = local if isinstance(local, list) else []
        out=[]
        for i, v in enumerate(src):
            out.append(merge_preserve_local_secrets(v, local[i] if i < len(local) else None))
        return out
    return src


def is_loom_hook_command(command):
    if not isinstance(command, str):
        return False
    normalized = command.replace('\\', '/')
    return ' hook ' in command and any(pattern in command or pattern.replace('\\', '/') in normalized for pattern in LOOM_HOOK_COMMAND_PATTERNS)


def strip_loom_hooks_from_settings(data):
    if not isinstance(data, dict) or not isinstance(data.get('hooks'), dict):
        return data, False
    changed = False
    new_data = dict(data)
    new_hooks = {}
    for event, groups in data.get('hooks', {}).items():
        if not isinstance(groups, list):
            new_hooks[event] = groups
            continue
        cleaned_groups = []
        for group in groups:
            if not isinstance(group, dict):
                cleaned_groups.append(group)
                continue
            group_hooks = group.get('hooks', [])
            if not isinstance(group_hooks, list):
                cleaned_groups.append(group)
                continue
            remaining = []
            for hook in group_hooks:
                command = hook.get('command') if isinstance(hook, dict) else None
                if is_loom_hook_command(command):
                    changed = True
                    continue
                remaining.append(hook)
            if remaining:
                ng = dict(group)
                ng['hooks'] = remaining
                cleaned_groups.append(ng)
            elif len(group_hooks) != len(remaining):
                changed = True
        if cleaned_groups:
            new_hooks[event] = cleaned_groups
        elif groups:
            changed = True
    if changed:
        new_data['hooks'] = new_hooks
    return new_data, changed


def prepare_json_for_export(data, item):
    if item.get('strip_loom_hooks'):
        data, stripped = strip_loom_hooks_from_settings(data)
        if stripped:
            log(f'stripped local loom hooks from export {item["name"]}')
    return data


def export_local(manifest):
    changed=[]
    patterns=manifest.get('exclude_globs', [])
    for item in manifest['managed_files']:
        src = HUB / item['source']
        tgt = Path(item['target'])
        if not tgt.exists():
            continue
        if is_excluded(tgt, patterns):
            continue
        src.parent.mkdir(parents=True, exist_ok=True)
        if item['type'] == 'dir':
            copy_dir(tgt, src, patterns)
        elif item['type'] == 'json':
            data = validate_json(tgt)
            if contains_sensitive_key(data):
                log(f'skip sensitive json export {item["name"]}: {tgt}')
                continue
            data = prepare_json_for_export(data, item)
            src.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n')
        else:
            copy_file(tgt, src, item.get('mode'))
        changed.append(item['name'])
    return changed


def apply_repo(manifest):
    applied=[]
    patterns=manifest.get('exclude_globs', [])
    backup_root=manifest.get('backup_root', '/home/neo/.loom-backups')
    for item in manifest['managed_files']:
        src = HUB / item['source']
        tgt = Path(item['target'])
        if not src.exists():
            continue
        if item.get('schema') == 'codex-hooks' or (item['type'] == 'json' and tgt.name == 'hooks.json' and '.codex' in str(tgt)):
            validate_codex_hooks(src)
        elif item['type'] == 'json':
            validate_json(src)
        backup_target(tgt, backup_root)
        if item['type'] == 'dir':
            copy_dir(src, tgt, patterns)
        elif item['type'] == 'json':
            source_data = validate_json(src)
            local_data = validate_json(tgt) if tgt.exists() and tgt.read_text().strip() else None
            merged = merge_preserve_local_secrets(source_data, local_data)
            ensure_parent(tgt)
            tgt.write_text(json.dumps(merged, indent=2, ensure_ascii=False) + '\n')
        else:
            copy_file(src, tgt, item.get('mode'))
        applied.append(item['name'])
    return applied


def git_has_repo():
    return bool(HUB) and (HUB / '.git').exists()


def git_init_if_needed():
    if not git_has_repo():
        run(['git', 'init'], check=True)
        run(['git', 'branch', '-M', 'main'], check=False)
    gitignore = HUB / '.gitignore'
    if not gitignore.exists():
        gitignore.write_text('\n'.join(['logs/*.log', '.loom.lock', 'state/*.tmp', '', '# never store secrets/caches', '**/auth.json', '**/*credentials*.json', '**/oauth*.json', '**/node_modules/', '**/tmp/', '**/cache/', '**/sessions/', '**/*.db*']) + '\n')


def git_commit(message):
    git_init_if_needed()
    run(['git', 'add', '-A'], check=True)
    status = run(['git', 'status', '--porcelain']).stdout.strip()
    if not status:
        return False
    run(['git', 'commit', '-m', message], check=True)
    return True



def git_status_porcelain():
    return run(['git', 'status', '--porcelain']).stdout.strip()


def assert_clean_worktree_for_sync():
    status = git_status_porcelain()
    if status:
        log('ERROR working tree is not clean; refusing sync before pull-first merge')
        log(status)
        raise RuntimeError('working tree has uncommitted changes; commit/stash them or run export/apply explicitly')

def has_origin():
    if not git_has_repo():
        return False
    return run(['git', 'remote', 'get-url', 'origin']).returncode == 0


def pull_rebase():
    if not has_origin():
        log('No git origin configured; skip pull')
        return False
    p=run(['git', 'pull', '--rebase', '--autostash', 'origin', 'main'])
    log(p.stdout.strip() or 'pull ok')
    return p.returncode == 0


def push():
    if not has_origin():
        log('No git origin configured; skip push')
        return False
    p=run(['git', 'push', 'origin', 'HEAD:main'])
    log(p.stdout.strip() or 'push ok')
    return p.returncode == 0


def escape_toml_basic(s):
    return s.replace('\\', '\\\\').replace('"', '\\"')


def codex_event_label(event):
    out=[]
    for i,ch in enumerate(event):
        if ch.isupper() and i:
            out.append('_')
        out.append(ch.lower())
    return ''.join(out)


def canonical_json(value):
    if isinstance(value, list):
        return [canonical_json(v) for v in value]
    if isinstance(value, dict):
        return {k: canonical_json(value[k]) for k in sorted(value)}
    return value


def codex_trusted_hash(event, entry, hook):
    identity = {
        'event_name': codex_event_label(event),
        'hooks': [{
            'type': hook.get('type', 'command'),
            'command': hook['command'],
            'timeout': max(1, hook.get('timeout', 600)),
            'async': False,
        }]
    }
    if entry.get('matcher'):
        identity['matcher'] = entry['matcher']
    payload = json.dumps(canonical_json(identity), separators=(',', ':'))
    return 'sha256:' + hashlib.sha256(payload.encode()).hexdigest()


def update_codex_config_trust(hooks_path):
    hooks_path = Path(hooks_path)
    config_path = hooks_path.parent / 'config.toml'
    if not config_path.exists() or not hooks_path.exists():
        return
    data = validate_codex_hooks(hooks_path)
    text = config_path.read_text()
    additions = []
    import re
    for event, entries in data.get('hooks', {}).items():
        label = codex_event_label(event)
        for gi, entry in enumerate(entries):
            for hi, hook in enumerate(entry.get('hooks', [])):
                if not isinstance(hook, dict) or hook.get('type') != 'command' or 'command' not in hook:
                    continue
                key = f'{hooks_path}:{label}:{gi}:{hi}'
                trusted = codex_trusted_hash(event, entry, hook)
                pattern = re.compile(r'(\[hooks\.state\."' + re.escape(key) + r'"\]\ntrusted_hash = ")[^"]*(")')
                if pattern.search(text):
                    text = pattern.sub(r'\1' + trusted + r'\2', text)
                else:
                    additions.append(f'\n[hooks.state."{escape_toml_basic(key)}"]\ntrusted_hash = "{trusted}"\n')
    if additions:
        if not text.endswith('\n'):
            text += '\n'
        text += ''.join(additions)
    config_path.write_text(text)


def hook_phase_for_event(event):
    e = str(event).lower()
    if e in ('stop', 'sessionend', 'session_end', 'exit'):
        return 'exit'
    return 'start'



def hook_command_contains(command, needle):
    return isinstance(command, str) and needle in command


def is_codex_native_hook_command(command):
    return hook_command_contains(command, 'codex-native-hook.js')


def is_fable5_wrapper_command(command):
    return hook_command_contains(command, 'claude-fable5-user-prompt-wrapper.js')


def split_command(command):
    try:
        return shlex.split(command, posix=not windows_platform())
    except Exception:
        try:
            return shlex.split(command)
        except Exception:
            return []


def extract_native_hook_parts(command):
    parts = split_command(command)
    hook_path = None
    node_path = None
    for i, part in enumerate(parts):
        if str(part).endswith('codex-native-hook.js'):
            hook_path = part
            if i > 0:
                node_path = parts[i - 1]
            break
    if not hook_path:
        return None, None
    if not node_path or node_path.startswith('-'):
        node_path = shutil.which('node') or 'node'
    return node_path, hook_path


def default_codex_native_hook_command(groups):
    for group in groups:
        for hook in group.get('hooks', []) if isinstance(group, dict) else []:
            command = hook.get('command') if isinstance(hook, dict) else None
            if is_codex_native_hook_command(command):
                return command
    fallback_hook = Path.home() / '.bun' / 'install' / 'global' / 'node_modules' / 'oh-my-codex' / 'dist' / 'scripts' / 'codex-native-hook.js'
    node = shutil.which('node') or '/home/neo/n/bin/node'
    return f'{quote_command_path(node)} {quote_command_path(fallback_hook)}'


def fable5_wrapper_command(native_command):
    node, native_hook = extract_native_hook_parts(native_command)
    if not native_hook:
        native_hook = str(Path.home() / '.bun' / 'install' / 'global' / 'node_modules' / 'oh-my-codex' / 'dist' / 'scripts' / 'codex-native-hook.js')
    if not node:
        node = shutil.which('node') or 'node'
    wrapper = Path.home() / '.codex' / 'hooks' / 'claude-fable5-user-prompt-wrapper.js'
    return f'{quote_command_path(node)} {quote_command_path(wrapper)} --omx-native-hook {quote_command_path(native_hook)}'


def ensure_codex_fable5_user_prompt_hook(settings, data):
    hooks = data.setdefault('hooks', {})
    groups = hooks.setdefault('UserPromptSubmit', [])
    native_command = default_codex_native_hook_command(groups)
    wrapper_command = fable5_wrapper_command(native_command)
    changed = False
    cleaned = []
    wrapper_present = False
    for group in groups:
        if not isinstance(group, dict):
            cleaned.append(group)
            continue
        group_hooks = group.get('hooks', [])
        if not isinstance(group_hooks, list):
            cleaned.append(group)
            continue
        remaining = []
        group_has_wrapper = False
        for hook in group_hooks:
            command = hook.get('command') if isinstance(hook, dict) else None
            if is_fable5_wrapper_command(command):
                new_hook = dict(hook)
                if new_hook.get('command') != wrapper_command or new_hook.get('timeout') != 30:
                    new_hook['command'] = wrapper_command
                    new_hook['timeout'] = 30
                    changed = True
                remaining.append(new_hook)
                group_has_wrapper = True
                wrapper_present = True
            elif is_codex_native_hook_command(command):
                # The wrapper runs the native hook first and merges its output, so a separate
                # UserPromptSubmit native hook would duplicate OMX prompt context.
                changed = True
            else:
                remaining.append(hook)
        if remaining:
            ng = dict(group)
            ng['hooks'] = remaining
            cleaned.append(ng)
        elif group_hooks and not group_has_wrapper:
            changed = True
    if not wrapper_present:
        cleaned.insert(0, {'hooks': [{'type': 'command', 'command': wrapper_command, 'timeout': 30}]})
        changed = True
    if changed or cleaned != groups:
        hooks['UserPromptSubmit'] = cleaned
        settings.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n')
    return changed


def codex_user_prompt_commands(data):
    hooks = data.get('hooks', {}) if isinstance(data, dict) else {}
    groups = hooks.get('UserPromptSubmit', []) if isinstance(hooks, dict) else []
    commands = []
    for group in groups if isinstance(groups, list) else []:
        for hook in group.get('hooks', []) if isinstance(group, dict) else []:
            if isinstance(hook, dict) and hook.get('type', 'command') == 'command':
                command = hook.get('command')
                if isinstance(command, str):
                    commands.append(command)
    return commands



def validate_global_memory_markers(manifest, scope='repo'):
    errors = []
    for item in manifest.get('managed_files', []):
        source = item.get('source', '')
        if item.get('type') != 'file' or not source.lower().endswith(('.md', '.markdown')):
            continue
        # CLAUDE.md intentionally references the canonical memory file rather than embedding it.
        if item.get('name') == 'claude-md':
            continue
        path = HUB / source if scope == 'repo' else Path(item['target'])
        if not path.exists():
            continue
        text = path.read_text(errors='ignore')
        if 'GLOBAL-MEMORY:' not in text:
            continue
        for marker in REQUIRED_GLOBAL_MEMORY_MARKERS:
            if f'<!-- GLOBAL-MEMORY:{marker}:START -->' not in text or f'<!-- GLOBAL-MEMORY:{marker}:END -->' not in text:
                errors.append(f'{scope}:{path}: missing GLOBAL-MEMORY:{marker}')
    return errors

def validate_codex_runtime_invariants(data, path='codex hooks'):
    errors = []
    if not isinstance(data, dict) or set(data.keys()) != {'hooks'}:
        return [f'{path}: expected only top-level hooks key']
    commands = codex_user_prompt_commands(data)
    wrapper_commands = [c for c in commands if is_fable5_wrapper_command(c)]
    bare_native = [c for c in commands if is_codex_native_hook_command(c) and not is_fable5_wrapper_command(c)]
    if len(wrapper_commands) != 1:
        errors.append(f'{path}: expected exactly one claude-fable5 UserPromptSubmit wrapper, got {len(wrapper_commands)}')
    if bare_native:
        errors.append(f'{path}: UserPromptSubmit has bare codex-native-hook.js; it must be wrapped by claude-fable5-user-prompt-wrapper.js')
    if wrapper_commands:
        command = wrapper_commands[0]
        if '--omx-native-hook' not in command or 'codex-native-hook.js' not in command:
            errors.append(f'{path}: Fable5 wrapper must pass --omx-native-hook codex-native-hook.js')
    return errors


def validate_managed_invariants(manifest, scope='repo'):
    errors = []
    for item in manifest.get('managed_files', []):
        if item.get('name') != 'codex-hooks':
            continue
        path = HUB / item['source'] if scope == 'repo' else Path(item['target'])
        if not path.exists():
            errors.append(f'{scope}:{item["name"]}: missing {path}')
            continue
        try:
            data = validate_codex_hooks(path)
        except Exception as e:
            errors.append(f'{scope}:{item["name"]}: {e}')
            continue
        errors.extend(validate_codex_runtime_invariants(data, f'{scope}:{path}'))
    return errors


def assert_managed_invariants(manifest, scope='repo'):
    errors = validate_managed_invariants(manifest, scope)
    if errors:
        for error in errors:
            log('ERROR invariant failed: ' + error)
        raise RuntimeError(f'{scope} managed config invariants failed; refusing to commit or push')


def repair_local_before_export(manifest):
    install_hooks(manifest)
    assert_managed_invariants(manifest, scope='local')


def guarded_git_commit(manifest, message, scope='repo'):
    assert_managed_invariants(manifest, scope=scope)
    return git_commit(message)


def guarded_push(manifest):
    assert_managed_invariants(manifest, scope='repo')
    return push()

def install_hooks(manifest):
    installed=[]
    cli_path = cli_executable_path()
    hook_cmd = command_for_cli(cli_path) + ' hook --platform "{platform}"'
    for h in manifest.get('hook_install', []):
        platform=h['platform']; settings=Path(h['settings']); event=h['event']
        settings.parent.mkdir(parents=True, exist_ok=True)
        data={}
        if settings.exists() and settings.read_text().strip():
            data=json.loads(settings.read_text())
        hooks=data.setdefault('hooks', {})
        arr=hooks.setdefault(event, [])
        phase = hook_phase_for_event(event)
        cmd = hook_cmd.format(platform=platform) + f' --phase {phase}'
        if platform == 'codex' and phase == 'exit':
            log_file = LOG_DIR / 'codex-stop-hook.log'
            if windows_platform():
                ps = (
                    "& { "
                    f"New-Item -ItemType Directory -Force -LiteralPath '{LOG_DIR}' | Out-Null; "
                    f"& '{cli_path}' hook --platform {platform} --phase {phase} *>> '{log_file}'; "
                    "Write-Output '{}' "
                    "}"
                )
                cmd = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -Command ' + quote_command_path(ps)
            else:
                inner = (
                    f'mkdir -p {shlex.quote(str(LOG_DIR))}; '
                    f'{shlex.quote(str(cli_path))} hook --platform {shlex.quote(platform)} --phase {shlex.quote(phase)} '
                    f'>>{shlex.quote(str(log_file))} 2>&1; '
                    "printf '%s\\n' '{}'"
                )
                cmd = f'/bin/bash -lc {shlex.quote(inner)}'
        def is_agent_sync_hook(hook):
            return isinstance(hook, dict) and is_loom_hook_command(hook.get('command', ''))
        cleaned=[]
        changed=False
        for group in arr:
            group_hooks = group.get('hooks', []) if isinstance(group, dict) else []
            remaining = [hh for hh in group_hooks if not is_agent_sync_hook(hh)]
            if len(remaining) != len(group_hooks):
                changed=True
            if remaining:
                ng = dict(group)
                ng['hooks'] = remaining
                cleaned.append(ng)
        cleaned.append({'hooks':[{'type':'command','command':cmd,'timeout':30}]})
        hooks[event] = cleaned
        if changed or arr != cleaned:
            settings.write_text(json.dumps(data, indent=2, ensure_ascii=False)+'\n')
            installed.append(platform)
        if h.get('schema') == 'codex-hooks-json':
            if platform == 'codex' and ensure_codex_fable5_user_prompt_hook(settings, data):
                installed.append(platform + ':fable5')
            validate_codex_hooks(settings)
            update_codex_config_trust(settings)
    return installed


def doctor(manifest):
    errors=[]
    errors.extend(validate_managed_invariants(manifest, scope='repo'))
    errors.extend(validate_global_memory_markers(manifest, scope='repo'))
    for item in manifest['managed_files']:
        src=HUB/item['source']; tgt=Path(item['target'])
        if not src.exists(): errors.append(f'missing source {item["name"]}: {src}')
        if item['type']=='json' and src.exists():
            try:
                if item.get('schema') == 'codex-hooks': validate_codex_hooks(src)
                else: validate_json(src)
            except Exception as e: errors.append(str(e))
    for h in manifest.get('hook_install', []):
        p=Path(h['settings'])
        if p.exists():
            try:
                j=json.loads(p.read_text())
                if h.get('schema') == 'codex-hooks-json' and set(j.keys()) != {'hooks'}:
                    errors.append(f'{p} has invalid top-level keys {list(j.keys())}')
            except Exception as e: errors.append(f'{p}: {e}')
    if errors:
        for e in errors: log('ERROR '+e)
        return 1
    log('doctor ok')
    return 0


def acquire_lock():
    start=time.time()
    while True:
        try:
            fd=os.open(LOCK, os.O_CREAT|os.O_EXCL|os.O_WRONLY)
            os.write(fd, str(os.getpid()).encode()); os.close(fd); return
        except FileExistsError:
            if time.time()-start > 20:
                raise RuntimeError('loom lock timeout')
            time.sleep(0.5)


def release_lock():
    try: LOCK.unlink()
    except FileNotFoundError: pass


def default_user_bin_dir(target_os=None):
    system = (target_os or py_platform.system()).lower()
    if system in ('windows', 'win32', 'cygwin', 'msys'):
        base = os.environ.get('LOCALAPPDATA')
        if base:
            return Path(base) / 'Programs' / 'loom' / 'bin'
        return Path.home() / 'AppData' / 'Local' / 'Programs' / 'loom' / 'bin'
    return Path.home() / '.local' / 'bin'


def install_cli(target=None, mode='symlink'):
    require_hub()
    target_dir = Path(target).expanduser() if target else default_user_bin_dir()
    target_dir.mkdir(parents=True, exist_ok=True)
    source = cli_executable_path()
    dest_name = 'loom.exe' if windows_platform() else 'loom'
    dest = target_dir / dest_name
    if dest.exists() or dest.is_symlink():
        dest.unlink()
    if mode == 'copy' or windows_platform() or getattr(sys, 'frozen', False):
        shutil.copy2(source, dest)
    else:
        dest.symlink_to(source)
    dest.chmod(0o755)
    (target_dir / 'loom-hub.json').write_text(json.dumps({'hub': str(HUB)}, indent=2) + '\n')
    install_path_exports(target_dir)
    log(f'installed loom CLI to {dest}')
    return dest


def install_path_exports(*dirs):
    dirs = [str(Path(d).expanduser()) for d in dirs if d]
    if not dirs:
        return
    if os.environ.get('LOOM_SKIP_PATH_EXPORT') == '1':
        log('skip PATH export because LOOM_SKIP_PATH_EXPORT=1')
        return
    if windows_platform():
        log('Windows PATH is not edited automatically; add ' + dirs[0] + ' to PATH if you want to run loom from any shell')
        return
    export_path = ':'.join('$HOME' + d[len(str(Path.home())):] if d.startswith(str(Path.home())) else d for d in dirs)
    block = '# >>> loom path >>>\nexport PATH="' + export_path + ':$PATH"\n# <<< loom path <<<\n'
    for rc_name in ['.bashrc', '.zshrc']:
        rc = Path.home() / rc_name
        old = rc.read_text() if rc.exists() else ''
        if '# >>> loom path >>>' in old and '# <<< loom path <<<' in old:
            pre = old.split('# >>> loom path >>>')[0].rstrip()
            post = old.split('# <<< loom path <<<', 1)[1]
            rc.write_text(pre + '\n' + block + post)
        else:
            rc.write_text(old.rstrip() + '\n\n' + block)


def remove_block(text, start, end):
    changed = False
    while start in text and end in text:
        pre = text.split(start, 1)[0].rstrip()
        rest = text.split(start, 1)[1]
        post = rest.split(end, 1)[1].lstrip('\n')
        text = pre + ('\n' if pre and post else '') + post
        changed = True
    return text, changed


def cleanup_legacy_shims():
    removed=[]
    shimdir = HUB / 'shims'
    for name in ['codex', 'gemini', 'opencode', 'claude', 'hermes']:
        p = shimdir / name
        if p.exists() or p.is_symlink():
            p.unlink()
            removed.append(str(p))
    for rc_name in ['.bashrc', '.zshrc']:
        rc = Path.home() / rc_name
        if not rc.exists():
            continue
        old = rc.read_text()
        new_text, changed = remove_block(old, '# >>> loom shims >>>', '# <<< loom shims <<<')
        if changed:
            rc.write_text(new_text)
            removed.append(str(rc) + ':loom-shims-path-block')
    if removed:
        log('removed legacy command shims: ' + ', '.join(removed))
    else:
        log('legacy command shims already absent')
    return removed


def install_shims():
    # Deprecated by default: do not shadow real harness CLIs by putting same-name wrappers
    # earlier in PATH. This command now cleans up older shim installs instead.
    cleanup_legacy_shims()
    log('command shims are disabled by default; real harness CLIs are left untouched')
    return []


def systemd_user_dir():
    return Path.home() / '.config' / 'systemd' / 'user'


def macos_launch_agents_dir():
    return Path.home() / 'Library' / 'LaunchAgents'


def windows_startup_dir():
    base = os.environ.get('APPDATA')
    if base:
        return Path(base) / 'Microsoft' / 'Windows' / 'Start Menu' / 'Programs' / 'Startup'
    return Path.home() / 'AppData' / 'Roaming' / 'Microsoft' / 'Windows' / 'Start Menu' / 'Programs' / 'Startup'


def install_timer(interval_minutes=5, target_os=None):
    require_hub()
    interval_minutes = max(1, int(interval_minutes))
    system = (target_os or py_platform.system()).lower()
    if system in ('linux', 'linux2'):
        return install_linux_timer(interval_minutes)
    if system in ('darwin', 'mac', 'macos'):
        return install_macos_timer(interval_minutes)
    if system in ('windows', 'win32', 'cygwin', 'msys'):
        return install_windows_timer(interval_minutes)
    log(f'unsupported timer platform: {system}')
    return False


def install_linux_timer(interval_minutes):
    user_dir = systemd_user_dir()
    user_dir.mkdir(parents=True, exist_ok=True)
    service = user_dir / 'loom-sync.service'
    timer = user_dir / 'loom-sync.timer'
    service.write_text(
        '[Unit]\n'
        'Description=Sync agent harness configuration hub\n\n'
        '[Service]\n'
        'Type=oneshot\n'
        f'WorkingDirectory={HUB}\n'
        f'ExecStart={cli_executable_path(target_os="linux")} hook --platform timer --phase timer\n'
    )
    timer.write_text(
        '[Unit]\n'
        'Description=Periodic sync for agent harness configuration hub\n\n'
        '[Timer]\n'
        'OnBootSec=2min\n'
        f'OnUnitActiveSec={interval_minutes}min\n'
        'Persistent=true\n\n'
        '[Install]\n'
        'WantedBy=timers.target\n'
    )
    if shutil.which('systemctl'):
        run(['systemctl', '--user', 'daemon-reload'], cwd=HUB, capture=True)
        enable = run(['systemctl', '--user', 'enable', '--now', 'loom-sync.timer'], cwd=HUB, capture=True)
        if enable.returncode != 0:
            log('Linux timer files installed, but systemctl enable failed: ' + (enable.stdout or '').strip())
            return False
        log(f'installed and enabled Linux systemd user timer every {interval_minutes} minutes')
        return True
    log('Linux timer files installed, but systemctl command not found')
    return False


def install_macos_timer(interval_minutes):
    launch_dir = macos_launch_agents_dir()
    launch_dir.mkdir(parents=True, exist_ok=True)
    plist = launch_dir / 'com.neo.loom.sync.plist'
    interval_seconds = interval_minutes * 60
    plist_text = '\n'.join([
        f'<?xml version="1.0" encoding="UTF-8"?>',
        f'<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">',
        f'<plist version="1.0">',
        f'<dict>',
        f'  <key>Label</key>',
        f'  <string>com.loom.sync</string>',
        f'  <key>ProgramArguments</key>',
        f'  <array>',
        f'    <string>{cli_executable_path(target_os="macos")}</string>',
        f'    <string>hook</string>',
        f'    <string>--platform</string>',
        f'    <string>timer</string>',
        f'    <string>--phase</string>',
        f'    <string>timer</string>',
        f'  </array>',
        f'  <key>WorkingDirectory</key>',
        f'  <string>{HUB}</string>',
        f'  <key>StartInterval</key>',
        f'  <integer>{interval_seconds}</integer>',
        f'  <key>RunAtLoad</key>',
        f'  <true/>',
        f'  <key>StandardOutPath</key>',
        f'  <string>{HUB}/logs/launchd.out.log</string>',
        f'  <key>StandardErrorPath</key>',
        f'  <string>{HUB}/logs/launchd.err.log</string>',
        f'</dict>',
        f'</plist>',
        ''
    ])
    plist.write_text(plist_text)
    if shutil.which('launchctl'):
        run(['launchctl', 'unload', str(plist)], cwd=HUB, capture=True)
        load = run(['launchctl', 'load', '-w', str(plist)], cwd=HUB, capture=True)
        if load.returncode != 0:
            log('macOS launchd plist installed, but launchctl load failed: ' + (load.stdout or '').strip())
            return False
        log(f'installed and loaded macOS launchd timer every {interval_minutes} minutes')
        return True
    log(f'macOS launchd plist installed at {plist}; run launchctl load -w {plist}')
    return False


def install_windows_timer(interval_minutes):
    scripts_dir = HUB / 'scripts'
    scripts_dir.mkdir(parents=True, exist_ok=True)
    ps1 = scripts_dir / 'loom-timer.ps1'
    ps1.write_text(
        '$ErrorActionPreference = "SilentlyContinue"\n'
        f'Set-Location -LiteralPath "{HUB}"\n'
        f'& "{cli_executable_path(target_os="windows")}" hook --platform timer --phase timer *>> "{HUB}/logs/windows-task.log"\n'
    )
    task_name = 'LoomSync'
    if shutil.which('schtasks'):
        create = run(['schtasks', '/Create', '/TN', task_name, '/SC', 'MINUTE', '/MO', str(interval_minutes), '/TR', f'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "{ps1}"', '/F'], cwd=HUB, capture=True)
        if create.returncode != 0:
            log('Windows scheduled task script installed, but schtasks create failed: ' + (create.stdout or '').strip())
            return False
        log(f'installed Windows Scheduled Task {task_name} every {interval_minutes} minutes')
        return True
    startup = windows_startup_dir()
    startup.mkdir(parents=True, exist_ok=True)
    starter = startup / 'loom-sync.cmd'
    starter.write_text('@echo off\r\n' + f'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "{ps1}"\r\n')
    log(f'Windows timer script installed at {ps1}; schtasks not found, startup fallback written to {starter}')
    return False


def timer_status(target_os=None):
    system = (target_os or py_platform.system()).lower()
    if system in ('linux', 'linux2') and shutil.which('systemctl'):
        p = run(['systemctl', '--user', 'list-timers', 'loom-sync.timer', '--no-pager'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no systemd timer status output')
        return p.returncode
    if system in ('darwin', 'mac', 'macos') and shutil.which('launchctl'):
        p = run(['launchctl', 'list', 'com.neo.loom.sync'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no launchd status output')
        return p.returncode
    if system in ('windows', 'win32', 'cygwin', 'msys') and shutil.which('schtasks'):
        p = run(['schtasks', '/Query', '/TN', 'LoomSync'], cwd=HUB, capture=True)
        log((p.stdout or '').strip() or 'no schtasks status output')
        return p.returncode
    log(f'no native timer status command available for {system}')
    return 1

def install_all(args):
    install_cli(args.cli_target, args.cli_mode)
    install_hooks(load_manifest())
    install_shims()
    install_timer(args.interval_minutes, args.platform)
    return doctor(load_manifest())


def cmd_sync(args):
    manifest=load_manifest(); git_init_if_needed()
    phase = getattr(args, "phase", "manual")
    platform = getattr(args, "platform", "manual")
    if should_skip_auto_sync(args):
        return 0
    log(f'sync begin platform={platform} phase={phase}')
    assert_clean_worktree_for_sync()
    if has_origin():
        if not pull_rebase():
            raise RuntimeError('pull/rebase failed; refusing to apply, export, commit, or push')
    else:
        log('No git origin configured; running local-only sync')
    assert_managed_invariants(manifest, scope='repo')
    applied=apply_repo(manifest); log(f'applied {len(applied)} managed entries')
    install_hooks(manifest)
    install_shims()
    assert_managed_invariants(manifest, scope='local')
    changed=export_local(manifest); log(f'exported {len(changed)} managed entries after remote apply')
    assert_managed_invariants(manifest, scope='repo')
    rc = doctor(manifest)
    if rc != 0:
        raise RuntimeError('doctor failed after merge/export; refusing to commit or push')
    guarded_git_commit(manifest, f'loom: sync merged healthy config {dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")}', scope='repo')
    guarded_push(manifest)
    if rc == 0:
        mark_auto_sync(args)
    return rc


def configure_hub(hub_arg):
    global HUB, MANIFEST, LOCK, LOG_DIR, STATE_DIR
    if not hub_arg:
        return
    hub = Path(hub_arg).expanduser().resolve()
    if not valid_hub(hub):
        raise RuntimeError(f'Invalid loom hub path: {hub} (missing config/manifest.json)')
    HUB = hub
    MANIFEST = HUB / 'config' / 'manifest.json'
    LOCK = HUB / '.loom.lock'
    LOG_DIR = HUB / 'logs'
    STATE_DIR = HUB / 'state'


def add_hub_arg(parser):
    parser.add_argument('--hub', default=argparse.SUPPRESS, help='Path to the loom checkout containing config/manifest.json.')
    return parser


def main():
    ap=argparse.ArgumentParser()
    ap.add_argument('--hub', default=None, help='Path to the loom checkout containing config/manifest.json. Overrides LOOM_HUB and loom-hub.json.')
    sub=ap.add_subparsers(dest='cmd', required=True)
    ip=add_hub_arg(sub.add_parser('install')); ip.add_argument('--cli-target', default=None); ip.add_argument('--cli-mode', choices=['symlink','copy'], default='symlink'); ip.add_argument('--interval-minutes', type=int, default=5); ip.add_argument('--platform', choices=['linux','macos','windows'], default=None)
    add_hub_arg(sub.add_parser('export'))
    add_hub_arg(sub.add_parser('apply'))
    add_hub_arg(sub.add_parser('sync'))
    add_hub_arg(sub.add_parser('doctor'))
    add_hub_arg(sub.add_parser('install-hooks'))
    cp=add_hub_arg(sub.add_parser('install-cli')); cp.add_argument('--target', default=None); cp.add_argument('--mode', choices=['symlink','copy'], default='symlink')
    add_hub_arg(sub.add_parser('install-shims'))
    tp=add_hub_arg(sub.add_parser('install-timer')); tp.add_argument('--interval-minutes', type=int, default=5); tp.add_argument('--platform', choices=['linux','macos','windows'], default=None)
    tsp=add_hub_arg(sub.add_parser('timer-status')); tsp.add_argument('--platform', choices=['linux','macos','windows'], default=None)
    hp=add_hub_arg(sub.add_parser('hook')); hp.add_argument('--platform', default='unknown'); hp.add_argument('--phase', default='start', choices=['start', 'exit', 'timer', 'manual']); hp.add_argument('--force', action='store_true')
    args=ap.parse_args()
    try:
        configure_hub(getattr(args, 'hub', None))
    except Exception as e:
        print(str(e))
        return 1
    if args.cmd == 'install':
        try:
            return install_all(args)
        except Exception as e:
            log(f'install failed: {e}')
            return 1
    locked = False
    try:
        require_hub()
        acquire_lock(); locked = True
        manifest=load_manifest(); git_init_if_needed()
        if args.cmd == 'export':
            repair_local_before_export(manifest)
            changed=export_local(manifest); log(f'exported {len(changed)} managed entries')
            guarded_git_commit(manifest, f'loom: export local config {dt.datetime.now().isoformat()}', scope='repo')
            return 0
        if args.cmd == 'apply':
            if not pull_rebase():
                raise RuntimeError('pull/rebase failed; refusing to apply')
            assert_managed_invariants(manifest, scope='repo')
            applied=apply_repo(manifest); log(f'applied {len(applied)} managed entries')
            install_hooks(manifest); install_shims()
            assert_managed_invariants(manifest, scope='local')
            return doctor(manifest)
        if args.cmd == 'sync': return cmd_sync(args)
        if args.cmd == 'doctor': return doctor(manifest)
        if args.cmd == 'install-hooks':
            installed=install_hooks(manifest); log('installed hooks: '+', '.join(installed)); return doctor(manifest)
        if args.cmd == 'install-cli':
            install_cli(args.target, args.mode); return doctor(manifest)
        if args.cmd == 'install-shims':
            install_shims(); return 0
        if args.cmd == 'install-timer':
            install_timer(args.interval_minutes, args.platform); return doctor(manifest)
        if args.cmd == 'timer-status':
            return timer_status(args.platform)
        if args.cmd == 'hook':
            # Harness startup path: never block startup on remote/network failure.
            try: return cmd_sync(args)
            except Exception as e:
                log(f'hook sync skipped/failed for {args.platform}: {e}')
                return 0
    except RuntimeError as e:
        print(str(e))
        return 1
    finally:
        if locked:
            release_lock()

if __name__ == '__main__':
    sys.exit(main())
