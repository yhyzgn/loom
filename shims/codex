#!/usr/bin/env bash
set -uo pipefail
LOOM_HUB="/home/neo/Projects/neo/pub/loom"
LOOM_PLATFORM="codex"
LOOM_REAL="/home/neo/.bun/bin/codex"
LOOM_LOG="/tmp/loom-codex.log"
loom_run() {
  local phase="$1"
  if [ "${LOOM_SHIM_BYPASS:-0}" != "1" ]; then
    LOOM_SHIM_BYPASS=1 "$LOOM_HUB/bin/loom" hook --platform "$LOOM_PLATFORM" --phase "$phase" >>"$LOOM_LOG" 2>&1 || true
  fi
}
loom_on_exit() {
  local status=$?
  loom_run exit
  exit "$status"
}
loom_run start
trap loom_on_exit EXIT
"$LOOM_REAL" "$@"
status=$?
exit "$status"
